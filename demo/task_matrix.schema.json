{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PRD to MVP task matrix",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "section",
      "milestone",
      "requirement",
      "category",
      "priority",
      "test_hint"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^REQ-\\d{3}$"
      },
      "section": {
        "type": "string",
        "minLength": 1
      },
      "milestone": {
        "type": "string",
        "pattern": "^M[1-3]-"
      },
      "requirement": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "type": "string",
        "enum": [
          "backend",
          "frontend",
          "core"
        ]
      },
      "priority": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low"
        ]
      },
      "test_hint": {
        "type": "string",
        "minLength": 1
      }
    },
    "additionalProperties": false
  }
}
